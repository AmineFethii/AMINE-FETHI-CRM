{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Represents a client in the CRM",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "serviceType": { "type": "string" },
        "progress": { "type": "number" },
        "statusMessage": { "type": "string" },
        "contractValue": { "type": "number" },
        "amountPaid": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["paid", "partial", "pending", "overdue"] },
        "missionStartDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name", "companyName", "serviceType", "progress", "statusMessage", "contractValue", "amountPaid", "paymentStatus", "missionStartDate"]
    }
  },
  "firestore": {
    "/clients/{clientId}": {
      "schema": { "$ref": "Client" },
      "description": "Collection of client documents"
    }
  }
}
